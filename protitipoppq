<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard PPA 2024–2027 · Ministério da Igualdade Racial</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0d0f14;
  --bg2: #13161e;
  --bg3: #1a1e28;
  --bg4: #22273a;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.12);
  --text: #f0f2f7;
  --text2: #9aa0b4;
  --text3: #6b7391;
  --green: #22c98e;
  --green-bg: rgba(34,201,142,0.12);
  --amber: #f5a623;
  --amber-bg: rgba(245,166,35,0.12);
  --red: #f05252;
  --red-bg: rgba(240,82,82,0.12);
  --blue: #4f8ef7;
  --blue-bg: rgba(79,142,247,0.12);
  --purple: #a78bfa;
  --purple-bg: rgba(167,139,250,0.12);
  --font: 'DM Sans', sans-serif;
  --mono: 'DM Mono', monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  line-height: 1.6;
  font-size: 14px;
}

/* HEADER */
.topbar {
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  padding: 0 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60px;
  position: sticky;
  top: 0;
  z-index: 100;
  gap: 1rem;
}
.topbar-left { display: flex; align-items: center; gap: 12px; }
.logo-mark {
  width: 32px; height: 32px;
  background: linear-gradient(135deg, #22c98e, #4f8ef7);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 600; color: #fff;
  flex-shrink: 0;
}
.topbar-title { font-size: 13px; font-weight: 500; color: var(--text); }
.topbar-sub { font-size: 11px; color: var(--text3); }
.topbar-right { display: flex; align-items: center; gap: 8px; }
.badge {
  font-size: 10px; font-weight: 500;
  padding: 3px 9px; border-radius: 20px;
  border: 1px solid;
}
.badge-green { color: var(--green); border-color: rgba(34,201,142,0.3); background: var(--green-bg); }
.badge-amber { color: var(--amber); border-color: rgba(245,166,35,0.3); background: var(--amber-bg); }
.badge-red { color: var(--red); border-color: rgba(240,82,82,0.3); background: var(--red-bg); }
.badge-blue { color: var(--blue); border-color: rgba(79,142,247,0.3); background: var(--blue-bg); }
.badge-purple { color: var(--purple); border-color: rgba(167,139,250,0.3); background: var(--purple-bg); }

/* LAYOUT */
.wrapper { max-width: 1200px; margin: 0 auto; padding: 2rem; }
.section-label {
  font-size: 10px; font-weight: 500; letter-spacing: .1em;
  text-transform: uppercase; color: var(--text3);
  margin: 2rem 0 1rem; display: flex; align-items: center; gap: 8px;
}
.section-label::after {
  content: ''; flex: 1; height: 1px; background: var(--border);
}

/* CARDS */
.card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.25rem;
}
.card-title {
  font-size: 11px; font-weight: 500;
  color: var(--text3); text-transform: uppercase;
  letter-spacing: .06em; margin-bottom: 1rem;
}

/* KPI GRID */
.kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 12px; }
.kpi-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 12px; padding: 1.25rem 1.25rem 1rem;
  position: relative; overflow: hidden;
  transition: border-color .2s;
}
.kpi-card:hover { border-color: var(--border2); }
.kpi-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
}
.kpi-card.green::before { background: var(--green); }
.kpi-card.amber::before { background: var(--amber); }
.kpi-card.red::before { background: var(--red); }
.kpi-card.blue::before { background: var(--blue); }
.kpi-label { font-size: 11px; color: var(--text3); margin-bottom: .5rem; line-height: 1.4; }
.kpi-value { font-size: 28px; font-weight: 600; line-height: 1; }
.kpi-value.green { color: var(--green); }
.kpi-value.amber { color: var(--amber); }
.kpi-value.red { color: var(--red); }
.kpi-value.blue { color: var(--blue); }
.kpi-sub { font-size: 11px; color: var(--text3); margin-top: .4rem; }
.kpi-pct {
  font-size: 10px; font-family: var(--mono);
  padding: 2px 6px; border-radius: 4px; display: inline-block; margin-top: .4rem;
}
.kpi-pct.green { background: var(--green-bg); color: var(--green); }
.kpi-pct.amber { background: var(--amber-bg); color: var(--amber); }
.kpi-pct.red { background: var(--red-bg); color: var(--red); }

/* 2 COL */
.row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
.row3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-bottom: 12px; }

/* PROG BARS */
.prog-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.prog-code {
  font-size: 10px; font-family: var(--mono); font-weight: 500;
  color: var(--text3); width: 36px; flex-shrink: 0;
}
.prog-name { font-size: 12px; color: var(--text2); flex: 1; line-height: 1.3; }
.prog-stack { display: flex; gap: 2px; width: 160px; flex-shrink: 0; border-radius: 4px; overflow: hidden; height: 12px; }
.prog-seg { height: 100%; }
.prog-total { font-size: 10px; font-family: var(--mono); color: var(--text3); width: 24px; text-align: right; flex-shrink: 0; }

/* H BARS */
.hbar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.hbar-label { font-size: 12px; color: var(--text2); width: 100px; flex-shrink: 0; }
.hbar-track { flex: 1; background: var(--bg4); border-radius: 4px; height: 8px; overflow: hidden; }
.hbar-fill { height: 100%; border-radius: 4px; transition: width .6s ease; }
.hbar-val { font-size: 11px; font-family: var(--mono); color: var(--text3); width: 36px; text-align: right; flex-shrink: 0; }

/* STATUS LIST */
.status-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: .5rem 0; border-bottom: 1px solid var(--border);
  font-size: 12px;
}
.status-row:last-child { border-bottom: none; }
.status-name { color: var(--text2); flex: 1; }
.status-count {
  font-family: var(--mono); font-size: 13px; font-weight: 500;
  min-width: 28px; text-align: right;
}

/* RISK */
.risk-item {
  display: flex; gap: 10px; padding: .75rem 0;
  border-bottom: 1px solid var(--border);
  align-items: flex-start;
}
.risk-item:last-child { border-bottom: none; }
.risk-badge-pill {
  font-size: 9px; font-weight: 600; letter-spacing: .05em;
  padding: 3px 8px; border-radius: 3px; flex-shrink: 0;
  margin-top: 2px; text-transform: uppercase;
}
.rb-critico { background: var(--red-bg); color: var(--red); }
.rb-moderado { background: var(--amber-bg); color: var(--amber); }
.rb-atencao { background: var(--blue-bg); color: var(--blue); }
.risk-text { font-size: 12px; color: var(--text2); line-height: 1.6; }
.risk-text strong { color: var(--text); font-weight: 500; }

/* INSIGHT */
.insight-item {
  display: flex; gap: 10px; padding: .6rem 0;
  border-bottom: 1px solid var(--border); align-items: flex-start;
}
.insight-item:last-child { border-bottom: none; }
.i-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; margin-top: 5px; }
.insight-text { font-size: 12px; color: var(--text2); line-height: 1.6; }
.insight-text strong { color: var(--text); font-weight: 500; }

/* REC */
.rec-item {
  display: flex; gap: 10px; padding: .6rem 0;
  border-bottom: 1px solid var(--border);
}
.rec-item:last-child { border-bottom: none; }
.rec-num {
  font-family: var(--mono); font-size: 10px; font-weight: 500;
  color: var(--text3); flex-shrink: 0; margin-top: 2px;
  width: 20px;
}
.rec-text { font-size: 12px; color: var(--text2); line-height: 1.6; }
.rec-text strong { color: var(--text); font-weight: 500; }

/* PARCEIRO */
.parceiro-row {
  display: flex; align-items: flex-start; justify-content: space-between;
  gap: 8px; padding: .5rem 0; border-bottom: 1px solid var(--border);
  font-size: 12px;
}
.parceiro-row:last-child { border-bottom: none; }
.parceiro-name { color: var(--text2); flex: 1; line-height: 1.4; }
.parceiro-badge {
  font-size: 10px; padding: 2px 7px; border-radius: 3px;
  font-family: var(--mono); flex-shrink: 0; margin-top: 1px;
}

/* STORYTELLING */
.story-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-left: 3px solid var(--blue);
  border-radius: 12px; padding: 1.5rem;
  font-size: 13px; color: var(--text2); line-height: 1.8;
  margin-bottom: 12px;
}
.story-card strong { color: var(--text); font-weight: 500; }

/* LEGEND */
.legend { display: flex; gap: 12px; margin-top: .75rem; flex-wrap: wrap; }
.legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--text3); }
.legend-dot { width: 8px; height: 8px; border-radius: 2px; }

/* DONUT */
.donut-wrap { display: flex; align-items: center; gap: 1.5rem; }
.donut-labels { display: flex; flex-direction: column; gap: 8px; flex: 1; }
.donut-label-row { display: flex; align-items: center; gap: 6px; font-size: 12px; }
.dl-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.dl-name { color: var(--text2); flex: 1; }
.dl-val { font-family: var(--mono); font-size: 12px; font-weight: 500; }

/* MIN STATUS CHIPS */
.min-chip-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
.min-chip {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 10px; padding: 1rem; text-align: center;
}
.min-chip .num { font-size: 24px; font-weight: 600; }
.min-chip .lbl { font-size: 10px; color: var(--text3); margin-top: 4px; line-height: 1.3; }

/* FOOTER */
.footer {
  border-top: 1px solid var(--border);
  margin-top: 3rem; padding: 1.5rem 2rem;
  font-size: 11px; color: var(--text3);
  display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px;
}

/* CHART SVG */
.chart-svg { width: 100%; overflow: visible; }

/* ANIMATION */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate { animation: fadeUp .5s ease forwards; opacity: 0; }
.d1 { animation-delay: .1s; }
.d2 { animation-delay: .2s; }
.d3 { animation-delay: .3s; }
.d4 { animation-delay: .4s; }
.d5 { animation-delay: .5s; }

@media (max-width: 900px) {
  .kpi-grid { grid-template-columns: repeat(2, 1fr); }
  .row2, .row3 { grid-template-columns: 1fr; }
  .topbar-right { display: none; }
}
@media (max-width: 500px) {
  .kpi-grid { grid-template-columns: 1fr 1fr; }
  .wrapper { padding: 1rem; }
}
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-left">
    <div class="logo-mark">MIR</div>
    <div>
      <div class="topbar-title">Dashboard PPA 2024–2027 · Ministério da Igualdade Racial</div>
      <div class="topbar-sub">Monitoramento de entregas e medidas institucionais · Referência: Dezembro 2025</div>
    </div>
  </div>
  <div class="topbar-right">
    <span class="badge badge-blue">5802 Povos Tradicionais</span>
    <span class="badge badge-amber">5803 Juventude Negra</span>
    <span class="badge badge-green">5804 Igualdade Racial</span>
  </div>
</div>

<div class="wrapper">

  <div class="section-label">Visão geral — KPIs executivos</div>

  <div class="kpi-grid">
    <div class="kpi-card blue animate d1">
      <div class="kpi-label">Total de entregas monitoradas</div>
      <div class="kpi-value blue">50</div>
      <div class="kpi-sub">Nos 3 programas do MIR</div>
    </div>
    <div class="kpi-card green animate d2">
      <div class="kpi-label">Metas cumpridas em 2025</div>
      <div class="kpi-value green">15</div>
