      <span class="kpi-pct green">30% do portfólio</span>
    </div>
    <div class="kpi-card amber animate d3">
      <div class="kpi-label">Entregas previstas (em curso)</div>
      <div class="kpi-value amber">8</div>
      <div class="kpi-sub">Instrumento ativo, prazo em 2026</div>
      <span class="kpi-pct amber">16% do portfólio</span>
    </div>
    <div class="kpi-card red animate d4">
      <div class="kpi-label">Entregas não previstas 2025</div>
      <div class="kpi-value red">27</div>
      <div class="kpi-sub">Sem instrumento ou fora do prazo</div>
      <span class="kpi-pct red">54% do portfólio</span>
    </div>
  </div>

  <div class="kpi-grid">
    <div class="kpi-card blue animate d1">
      <div class="kpi-label">Medidas institucionais (MIN)</div>
      <div class="kpi-value blue">42</div>
      <div class="kpi-sub">Total nos 3 programas</div>
    </div>
    <div class="kpi-card green animate d2">
      <div class="kpi-label">MIN concluídas em 2025</div>
      <div class="kpi-value green">8</div>
      <div class="kpi-sub">Medidas com entrega confirmada</div>
      <span class="kpi-pct green">19% das MIN</span>
    </div>
    <div class="kpi-card red animate d3">
      <div class="kpi-label">MIN sem conclusão em 2025</div>
      <div class="kpi-value red">34</div>
      <div class="kpi-sub">Maioria em aberto ou sem andamento</div>
      <span class="kpi-pct red">81% das MIN</span>
    </div>
    <div class="kpi-card amber animate d4">
      <div class="kpi-label">Entregas com restrições</div>
      <div class="kpi-value amber">24</div>
      <div class="kpi-sub">Pessoal, orçamento ou articulação</div>
      <span class="kpi-pct amber">48% do portfólio</span>
    </div>
  </div>

  <div class="section-label">Execução física por programa e secretaria</div>

  <div class="row2">
    <div class="card animate d1">
      <div class="card-title">Desempenho por programa — entregas 2025</div>

      <div class="prog-row">
        <div class="prog-code">5802</div>
        <div class="prog-name">Povos Tradicionais<br><span style="font-size:10px;color:var(--text3)">11 entregas</span></div>
        <div class="prog-stack">
          <div class="prog-seg" style="width:54.5%;background:var(--green)"></div>
          <div class="prog-seg" style="width:36.4%;background:var(--amber)"></div>
          <div class="prog-seg" style="width:9.1%;background:var(--red)"></div>
        </div>
        <div class="prog-total">55%</div>
      </div>

      <div class="prog-row">
        <div class="prog-code">5803</div>
        <div class="prog-name">Juventude Negra<br><span style="font-size:10px;color:var(--text3)">7 entregas</span></div>
        <div class="prog-stack">
          <div class="prog-seg" style="width:0%;background:var(--green)"></div>
          <div class="prog-seg" style="width:28.6%;background:var(--amber)"></div>
          <div class="prog-seg" style="width:71.4%;background:var(--red)"></div>
        </div>
        <div class="prog-total" style="color:var(--red)">0%</div>
      </div>

      <div class="prog-row">
        <div class="prog-code">5804</div>
        <div class="prog-name">Igualdade Racial<br><span style="font-size:10px;color:var(--text3)">32 entregas</span></div>
        <div class="prog-stack">
          <div class="prog-seg" style="width:28.1%;background:var(--green)"></div>
          <div class="prog-seg" style="width:6.3%;background:var(--amber)"></div>
          <div class="prog-seg" style="width:65.6%;background:var(--red)"></div>
        </div>
        <div class="prog-total" style="color:var(--amber)">28%</div>
      </div>

      <div class="legend">
        <div class="legend-item"><div class="legend-dot" style="background:var(--green)"></div>Meta cumprida</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--amber)"></div>Entrega prevista</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--red)"></div>Não prevista 2025</div>
      </div>
    </div>

    <div class="card animate d2">
      <div class="card-title">Desempenho por secretaria — % metas cumpridas</div>

      <div class="hbar-row">
        <div class="hbar-label">SQPT</div>
        <div class="hbar-track">
          <div class="hbar-fill" style="width:54.5%;background:var(--green)"></div>
        </div>
        <div class="hbar-val" style="color:var(--green)">55%</div>
      </div>
