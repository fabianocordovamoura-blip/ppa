        <div class="hbar-track"><div class="hbar-fill" style="width:23.8%;background:var(--amber)"></div></div>
        <div class="hbar-val" style="color:var(--amber)">24%</div>
      </div>
      <div style="font-size:10px;color:var(--text3);margin:-6px 0 0 80px">5 de 21</div>
    </div>

    <div class="card animate d2">
      <div class="card-title">Status MIN — Dezembro 2025</div>
      <div class="status-row">
