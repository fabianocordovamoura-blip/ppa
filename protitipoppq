      <div class="hbar-row">
        <div class="hbar-label">SENAPIR</div>
        <div class="hbar-track">
          <div class="hbar-fill" style="width:50%;background:var(--amber)"></div>
        </div>
        <div class="hbar-val" style="color:var(--amber)">50%</div>
      </div>
      <div style="font-size:10px;color:var(--text3);margin:-6px 0 10px 110px">3 cumpridas de 6</div>

      <div class="hbar-row">
        <div class="hbar-label">SEPAR</div>
        <div class="hbar-track">
          <div class="hbar-fill" style="width:20.7%;background:var(--amber)"></div>
        </div>
        <div class="hbar-val" style="color:var(--amber)">21%</div>
      </div>
      <div style="font-size:10px;color:var(--text3);margin:-6px 0 10px 110px">6 cumpridas de 29</div>

      <div class="hbar-row">
        <div class="hbar-label">Ouvidoria</div>
        <div class="hbar-track">
          <div class="hbar-fill" style="width:2%;background:var(--red)"></div>
        </div>
        <div class="hbar-val" style="color:var(--red)">0%</div>
      </div>
      <div style="font-size:10px;color:var(--text3);margin:-6px 0 10px 110px">0 cumpridas de 4</div>
    </div>
  </div>

  <div class="section-label">Medidas institucionais (MIN)</div>

  <div class="row3">
    <div class="card animate d1">
      <div class="card-title">MIN concluídas por programa</div>
      <div class="hbar-row">
        <div class="hbar-label" style="width:70px">5802</div>
        <div class="hbar-track"><div class="hbar-fill" style="width:16.7%;background:var(--green)"></div></div>
        <div class="hbar-val" style="color:var(--green)">17%</div>
      </div>
      <div style="font-size:10px;color:var(--text3);margin:-6px 0 10px 80px">3 de 18</div>
      <div class="hbar-row">
        <div class="hbar-label" style="width:70px">5803</div>
        <div class="hbar-track"><div class="hbar-fill" style="width:2%;background:var(--red)"></div></div>
